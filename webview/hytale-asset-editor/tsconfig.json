{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "allowArbitraryExtensions": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["../../src/shared/*"],
      "src/*": ["./src/*"]
    },
    "types": ["svelte", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "../../src/shared/**/*.ts",
    "../shared/**/*.ts",
    "../shared/**/*.svelte"
  ],
  "exclude": ["node_modules", "../../node_modules", "../../dist", "../../out", "../../media"]
}
