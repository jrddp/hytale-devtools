{
  "Id": "JumpIfToolArg",
  "Description": "Jump to a node based on a builder tool argument comparison.\n\nSupports checkbox/bool and dropdown/option types.",
  "Title": "Jump If Tool Arg",
  "Color": "purple",
  "Content": [
    {
      "Id": "ArgName",
      "Type": "SmallString",
      "Options": {
        "Description": "The tool arg name from the brush item",
        "Label": "Arg Name",
        "Width": 150
      }
    },
    {
      "Id": "ComparisonType",
      "Type": "Enum",
      "Options": {
        "Label": "Comparison Type",
        "Description": "The type of comparison to perform",
        "Width": 120,
        "Values": [
          "Equals",
          "NotEquals",
          "Contains"
        ]
      }
    },
    {
      "Id": "ComparisonValue",
      "Type": "SmallString",
      "Options": {
        "Description": "The value to compare against.\n\nFor boolean: 'true' or 'false'.\nfor string: the exact string or dropdown option.",
        "Label": "Comparison Value",
        "Width": 150
      }
    },
    {
      "Id": "StoredIndexName",
      "Type": "SmallString",
      "Options": {
        "Description": "The index to jump to.",
        "Label": "Stored Index Name",
        "Width": 150
      }
    }
  ],
  "Inputs": [
    {
      "Id": "OperationPin",
      "Type": "Operation",
      "Multiple": false,
      "Color": "blue"
    }
  ],
  "Schema": {
    "Id": "jumpiftoolarg",
    "ArgName": "ArgName",
    "ComparisonType": "ComparisonType",
    "ComparisonValue": "ComparisonValue",
    "StoredIndexName": "StoredIndexName"
  }
}
