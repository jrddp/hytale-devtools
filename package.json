  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && pnpm run build:webview && node esbuild.js",
    "watch": "npm-run-all -p watch:esbuild watch:webview watch:tsc",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:webview": "npm-run-all -p watch:webview:*",
    "watch:check:webview": "npm-run-all -p watch:check:webview:*",
    "watch:check:webview:node-editor": "pnpm --dir webview/hytale-node-editor exec svelte-check --tsconfig ./tsconfig.json --diagnostic-sources \"js\" --watch --preserveWatchOutput --output machine",
    "watch:check:webview:asset-editor": "pnpm --dir webview/hytale-asset-editor exec svelte-check --tsconfig ./tsconfig.json --diagnostic-sources \"js\" --watch --preserveWatchOutput --output machine",
    "watch:webview:node-editor": "pnpm --dir webview/hytale-node-editor run watch",
    "watch:webview:asset-editor": "pnpm --dir webview/hytale-asset-editor run watch",
    "dev:webview:node-editor": "pnpm --dir webview/hytale-node-editor run dev",
    "dev:webview:asset-editor": "pnpm --dir webview/hytale-asset-editor run dev",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "build:companion": "cd companion-mod && ./gradlew build",
    "package": "pnpm run check-types && pnpm run lint && pnpm run build:webview && node esbuild.js --production && pnpm run build:companion",
    "vsce:package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies",
    "build:webview": "npm-run-all build:webview:*",
    "build:webview:node-editor": "pnpm --dir webview/hytale-node-editor run build",
    "build:webview:asset-editor": "pnpm --dir webview/hytale-asset-editor run build",
    "compile-tests": "tsc -p . --outDir out",
    "compile-tests:node-editor-parser": "tsc -p tsconfig.node-editor-parser-tests.json",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "test:basic-schema-doc": "pnpm run compile-tests && node ./node_modules/mocha/bin/mocha.js \"out/test/basicSchemaDoc.test.js\"",
    "test:node-editor-parser": "pnpm run compile-tests:node-editor-parser && printf '{\"type\":\"module\"}\\n' > out-node-editor-parser-tests/package.json && node ./node_modules/mocha/bin/mocha.js \"out-node-editor-parser-tests/test/node-editor-parser/**/*.test.js\"",
    "test:node-editor-parser:vitest": "vitest --config vitest.config.mts run test/node-editor-parser",
    "test:node-editor-parser:vitest:watch": "vitest --config vitest.config.mts test/node-editor-parser",
    "test:asset-editor-parser:vitest": "vitest --config vitest.config.mts run test/asset-editor-parser",
    "test:asset-editor-parser:vitest:watch": "vitest --config vitest.config.mts test/asset-editor-parser",
    "asset-parse-memory-check": "bun run scripts/asset-parse-memory-check.ts",
    "asset-cache-runtime-check": "bun run scripts/asset-cache-runtime-check.ts",
    "test:node-editor-parse-basic": "node test/node-editor-parser/parse-basic.mjs",
    "check-types": "npm-run-all check-types:*",
    "check-types:extension": "tsc --noEmit",
    "check-types:webview:asset-editor": "pnpm --dir webview/hytale-asset-editor run check",
    "check-types:webview:node-editor": "pnpm --dir webview/hytale-node-editor run check",
    "lint": "eslint \"src/**/*.ts\" \"webview/**/*.svelte\" \"webview/**/*.ts\"",
    "update:asset-editor-selectors": "node scripts/updateAssetEditorSelectors.js",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "~20.19.35",
    "@types/vscode": "^1.104.0",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.21.5",
    "eslint": "^9.39.3",
    "eslint-plugin-svelte": "^3.15.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "svelte": "^5.53.6",
    "svelte-eslint-parser": "^1.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "yauzl": "^3.2.0"
  }
}
