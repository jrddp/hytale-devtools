{
  "name": "hytale-devtools",
  "displayName": "Hytale Devtools",
  "publisher": "jrddp",
  "icon": "media/icon.png",
  "description": "Built-in Worldgen v2 Node Editor, easily create mods+assets, and more",
  "repository": "https://github.com/jrddp/hytale-devtools",
  "version": "0.1.3",
  "packageManager": "pnpm@9.7.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Extension Packs",
    "Language Packs"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hytale-devtools.createMod",
        "title": "Create New Hytale Mod",
        "category": "Hytale Devtools"
      },
      {
        "command": "hytale-devtools.addListener",
        "title": "Add new event listener",
        "category": "Hytale Devtools"
      },
      {
        "command": "hytale-devtools.copyBaseGameAsset",
        "title": "Copy Base Game Asset",
        "category": "Hytale Devtools"
      },
      {
        "command": "hytale-devtools.changeModPatchline",
        "title": "Change Mod Support Version Patchline",
        "category": "Hytale Devtools"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.go-to-root",
        "title": "Go to Root",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.fit-view",
        "title": "Fit Full View",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.search-nodes",
        "title": "Search Nodes",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.select-all",
        "title": "Select All Nodes",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.auto-position-nodes",
        "title": "Auto Position Nodes",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.view-raw-json",
        "title": "View Raw JSON",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.help-and-hotkeys",
        "title": "Show Help",
        "category": "Hytale Node Editor",
        "enablement": "activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor'"
      }
    ],
    "keybindings": [
      {
        "command": "hytale-devtools.nodeEditor.quickAction.search-nodes",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "(activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor') && !inputFocus"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.select-all",
        "key": "ctrl+a",
        "mac": "cmd+a",
        "when": "(activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor') && !inputFocus"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.fit-view",
        "key": "v",
        "when": "(activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor') && !inputFocus"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.auto-position-nodes",
        "key": "l",
        "when": "(activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor') && !inputFocus"
      },
      {
        "command": "hytale-devtools.nodeEditor.quickAction.help-and-hotkeys",
        "key": "shift+/",
        "when": "(activeCustomEditorId == 'hytale-devtools.hytaleNodeEditor' || activeWebviewPanelId == 'hytale-devtools.hytaleNodeEditor') && !inputFocus"
      }
    ],
    "configuration": {
      "title": "Hytale Devtools",
      "properties": {
        "hytale-devtools.defaultAuthor": {
          "type": "string",
          "default": "",
          "description": "Default author name for new mods."
        },
        "hytale-devtools.defaultGroup": {
          "type": "string",
          "default": "",
          "description": "Default group name for new mods."
        },
        "hytale-devtools.defaultWebsite": {
          "type": "string",
          "default": "",
          "description": "Default website for new mods."
        },
        "hytale-devtools.customHytalePath": {
          "type": "string",
          "scope": "machine",
          "default": "",
          "description": "Optional custom Hytale root path for this machine. Set this to the root Hytale folder that contains subdirectories like \"install\" and \"UserData\". Defaults to typical install paths based on your operating system."
        },
        "hytale-devtools.nodeEditor.controlScheme": {
          "type": "string",
          "enum": [
            "mouse",
            "trackpad"
          ],
          "enumDescriptions": [
            "Pan with drag, zoom with scroll, and box-select with Shift+drag.",
            "Pan with scroll, zoom with pinch, and box-select with drag."
          ],
          "default": "mouse",
          "description": "Control scheme used by the Hytale Node Editor."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "hytale-devtools.hytaleNodeEditor",
        "displayName": "Hytale Node Editor",
        "selector": [
          {
            "filenamePattern": "**/Server/ScriptedBrushes/**/*.json"
          },
          {
            "filenamePattern": "**/Server/HytaleGenerator/Biomes/**/*.json"
          },
